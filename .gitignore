# ==============================================
# 后端 SpringBoot 忽略
# ===============================================
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

*.log
*.tmp
*.bak

# 配置文件敏感信息
application-dev.yml
application-prod.yml

# ==============================================
# 前端 Vue / Vite 忽略
# ===============================================
node_modules/
dist/
dist-ssr/
*.local

# 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 环境变量
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==============================================
# IDE 通用忽略（所有编辑器都忽略）
# ===============================================
.idea/
.vscode/
*.iml
*.iws
*.ipr
.DS_Store
*.swp
*.swo
*~

